node_modules/

# Generated assets. Rendered on demand from templates/ + data/, so there is no
# reason to version them. Committed preview copies live in docs/previews/.
output/

# TTF originals, only needed by build-logos.js to outline the crest lettering.
# Re-fetch with: node scripts/fetch-fonts.js
scripts/.ttf-cache/

# Local-only assets. This repo is PUBLIC, so anything that acts as a
# credential or contains personal contact details lives here and is never
# committed. See local/README.md (also ignored) for what belongs.
local/

# Belt and braces for the same class of file if it lands outside local/.
*WhatsApp*
*QR*code*
/*.png

# Anything rendered from a local-only asset. Invitations carry the group QR,
# so they stay out of the repo too.
docs/previews/invitation*
docs/previews/*-local.*

# Scratch
assets/logo/_contact-sheet.html
.DS_Store
Thumbs.db
*.log
